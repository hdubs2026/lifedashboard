NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
WEBHOOK_SECRET=
WHOOP_ACCESS_TOKEN=
NEXT_PUBLIC_APP_URL=https://lifedashboard-rose.vercel.app

# Jobber OAuth integration
# 1. Go to developer.getjobber.com and create an app
# 2. Set redirect URI to: https://lifedashboard-rose.vercel.app/api/jobber/callback
# 3. Copy Client ID and Secret below
# 4. Visit /api/jobber/auth once to complete the OAuth flow
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
CRON_SECRET=

# Gmail integration (for email task extraction)
# 1. Create a project at console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Run the one-time auth flow to get a refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
